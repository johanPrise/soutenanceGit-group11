# ==============================================
# .gitignore — soutenanceGit-group11
# Couvre : Node.js, Python, macOS, Linux, Windows,
#          IDEs (VSCode, JetBrains), outils divers
# ==============================================

# -----------------------------------------------
# 🖥️ Systèmes d'exploitation
# -----------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------
# 💻 Éditeurs & IDEs
# -----------------------------------------------

# Visual Studio Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains (IntelliJ, PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo

# -----------------------------------------------
# 🟢 Node.js / JavaScript / TypeScript
# -----------------------------------------------

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Builds
dist/
build/
.next/
out/
.nuxt/
.output/

# Variables d'environnement
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# -----------------------------------------------
# 🐍 Python
# -----------------------------------------------

__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Environnements virtuels
.venv/
venv/
env/
ENV/
.python-version

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/

# Tests & couverture
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Jupyter Notebooks
.ipynb_checkpoints/

# -----------------------------------------------
# 📦 Dépendances & Packages
# -----------------------------------------------

# Composer (PHP)
/vendor/

# Bundler (Ruby)
.bundle/

# -----------------------------------------------
# 🪵 Logs & fichiers temporaires
# -----------------------------------------------

*.log
logs/
*.pid
*.seed
*.pid.lock
tmp/
temp/

# -----------------------------------------------
# 🔐 Secrets & Credentials (NE JAMAIS COMMITTER)
# -----------------------------------------------

*.pem
*.key
*.cert
*.p12
*.pfx
secrets/
credentials/
